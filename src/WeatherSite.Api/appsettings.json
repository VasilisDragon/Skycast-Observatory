{
  "WeatherSite": {
    "UserAgent": "WeatherSite/1.0 (+https://weather.vasilis.club; contact@vasilis.club)",
    "ZipCentroidsPath": "App_Data/zcta-centroids.json",
    "ObservationFreshnessMinutes": 45,
    "CookieName": "weather_home_zip",
    "CookieLifetimeDays": 365,
    "DataProtectionKeysPath": "App_Data/DataProtectionKeys",
    "UseForwardedHeaders": true,
    "TrustedProxies": [ "192.168.1.102" ],
    "EnforceHttpsRedirection": true,
    "ApiRequestsPerMinute": 120,
    "TileRequestsPerMinute": 600,
    "Basemaps": {
      "WorldUrl": "/tiles/basemaps/world.pmtiles",
      "RegionalUrl": "/tiles/basemaps/usa.pmtiles"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "weather.vasilis.club"
}
